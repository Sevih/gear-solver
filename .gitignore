# dependencies / build
node_modules/
dist/
build/
.vite/
*.tsbuildinfo
coverage/

# synced asset/data cache (images + game data pulled from the outerpedia repo)
.cache/

# Electron desktop — packaged builds + downloaded bundled binaries (mitmdump,
# adb, …) + the prod-only mitmproxy CA (private key inside, NEVER commit).
# Both bin/ and prod-cert/ are reproducible from scripts/fetch-binaries.mjs.
apps/desktop/release/
apps/desktop/resources/bin/
apps/desktop/resources/prod-cert/

# capture runtime artifacts & PERSONAL account data — never commit
tools/capture/out/
tools/capture/dumps/
*.flows
*.log
*.log.err

# mitmproxy CA private material / duplicate PEM (the hashed .0 is kept for the one-button flow)
tools/capture/cert/mitmproxy-ca-cert.pem
tools/capture/cert/*.p12
tools/capture/cert/*-ca.pem

# OS / editor
.DS_Store
Thumbs.db
.idea/

