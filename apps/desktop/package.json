{
  "name": "@gear-solver/desktop",
  "version": "0.5.4",
  "private": true,
  "description": "Electron shell that hosts the gear-solver renderer and the capture pipeline in a single distributable.",
  "author": "Outerpedia",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p .",
    "start": "electron .",
    "dev": "tsc -p . && electron .",
    "typecheck": "tsc -p . --noEmit",
    "fetch-binaries": "node scripts/fetch-binaries.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.outerpedia.gear-solver",
    "productName": "Outerpedia Gear Solver",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "electronVersion": "42.4.1",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "extraMetadata": {
      "dependencies": {
        "electron-updater": "^6.3.9"
      }
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../data/derived",
        "to": "data/derived"
      },
      {
        "from": "../../data/build.mjs",
        "to": "data/build.mjs"
      },
      {
        "from": "../../data/calc-stats.mjs",
        "to": "data/calc-stats.mjs"
      },
      {
        "from": "../renderer/dist",
        "to": "renderer/dist"
      },
      {
        "from": "../../tools/capture/capture.ps1",
        "to": "tools/capture/capture.ps1"
      },
      {
        "from": "../../tools/capture/disarm.ps1",
        "to": "tools/capture/disarm.ps1"
      },
      {
        "from": "../../tools/capture/addon.py",
        "to": "tools/capture/addon.py"
      },
      {
        "from": "../../tools/capture/scripts",
        "to": "tools/capture/scripts"
      },
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/prod-cert",
        "to": "prod-cert",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Outerpedia Gear Solver"
    },
    "publish": {
      "provider": "github",
      "owner": "Sevih",
      "repo": "gear-solver"
    }
  }
}
